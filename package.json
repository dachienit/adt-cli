{
  "name": "adt-cli",
  "version": "0.1.0",
  "description": "Verbose, agent-friendly CLI for SAP ABAP Development Tools (ADT) HTTP services. Supports Basic auth and BTP OAuth, CSRF, cookies, profiles, and a generic request runner.",
  "type": "commonjs",
  "main": "src/cli.js",
  "bin": {
    "adt": "bin/adt.js",
    "adt-cli": "bin/adt.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "start": "node bin/adt.js",
    "smoke": "node bin/adt.js --help"
  },
  "keywords": [
    "abap",
    "adt",
    "sap",
    "cli",
    "agent",
    "btp",
    "oauth",
    "csrf",
    "rest",
    "developer-tools"
  ],
  "author": "Hau Le",
  "license": "UNLICENSED",
  "dependencies": {
    "@abaplint/core": "^2.119.21",
    "commander": "^12.1.0",
    "fast-xml-parser": "^5.8.0",
    "kerberos": "^7.0.0",
    "undici": "^7.25.0"
  }
}
